PORT=3847
JWT_SECRET=change-me-at-least-16-chars

# 可选；运行日志根目录（绝对路径，或相对启动时 cwd，默认 logs）。磁盘结构：LOG_DIR/年/月/YYYY-MM-DD.log
# LOG_DIR=logs

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_DATABASE=filedeal

# 开发时可 true：允许不传邀请码注册（生产务必 false 或不设置）
ALLOW_OPEN_REGISTRATION=false

# 可选；≥16 字符时启用 POST /auth/bootstrap-first-user，仅在库中无任何用户时创建首个账号
# BOOTSTRAP_INVITE_SECRET=

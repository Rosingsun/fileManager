PORT=3847
JWT_SECRET=change-me-at-least-16-chars

# 可选；运行日志根目录（绝对路径，或相对启动时 cwd，默认 logs）。磁盘结构：LOG_DIR/年/月/YYYY-MM-DD.log
# LOG_DIR=logs

# 建议 127.0.0.1；若写 localhost，服务端也会规范为 127.0.0.1，避免部分环境下 TCP 挂起导致登录无响应
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-mysql-password
MYSQL_DATABASE=filedeal

# 开发时可 true：允许不传邀请码注册（生产务必 false 或不设置）
ALLOW_OPEN_REGISTRATION=false

# 可选；≥16 字符时启用 POST /auth/bootstrap-first-user，仅在库中无任何用户时创建首个账号
# BOOTSTRAP_INVITE_SECRET=your-bootstrap-secret-at-least-16-chars

# 腾讯云 COS：勿写入本文件。在库表 app_parameters 中配置，或由管理员调用 POST /admin/parameters/cos 维护。
